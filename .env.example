# ===========================================================================
# .env.example
# ===========================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file to git.
# Add .env to your .gitignore immediately.
#
# Usage:
#   copy .env.example .env          (Windows PowerShell)
#   then edit .env with real values
# ===========================================================================


# ---------------------------------------------------------------------------
# Binance API Credentials
# ---------------------------------------------------------------------------
# Create a Binance API key at: https://www.binance.com/en/my/settings/api-management
#
# REQUIRED PERMISSIONS (check only these — nothing else):
#   [x] Read Info
#   [x] Enable Spot & Margin Trading
#
# RESTRICTIONS (set these for safety):
#   [x] Restrict access to trusted IPs only  ← set your home/server IP
#
# DO NOT enable:
#   [ ] Enable Withdrawals      ← NEVER
#   [ ] Enable Futures          ← not needed (spot only)
#   [ ] Enable Margin Loan      ← not needed
# ---------------------------------------------------------------------------

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here


# ---------------------------------------------------------------------------
# Live Trading Kill Switch
# ---------------------------------------------------------------------------
# BOTH of these must be set correctly for any real order to be placed.
# If either is missing or wrong, the bot runs in monitor-only mode.
#
# Step 1: Set LIVE_TRADING_ENABLED to true
# Step 2: Set LIVE_CONFIRM to exactly "YES_LIVE_TRADING" (no quotes in the file)
#
# Default: both disabled (safe)
# ---------------------------------------------------------------------------

LIVE_TRADING_ENABLED=false
LIVE_CONFIRM=NO


# ---------------------------------------------------------------------------
# Order Size Limit (USD)
# ---------------------------------------------------------------------------
# Hard cap on BUY order size in USD notional.
# This cannot exceed $50 in the code — even if you set it higher here.
# Start with $10 or $20 for the first few trades.
# ---------------------------------------------------------------------------

MAX_LIVE_NOTIONAL_USD=50


# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------
# After editing, rename this file to .env (no .example suffix).
# The live_trader.py and app.py load it automatically via python-dotenv.
#
# To enable live trading when ready:
#   1. Verify your API key works (check connection first)
#   2. Set LIVE_TRADING_ENABLED=true
#   3. Set LIVE_CONFIRM=YES_LIVE_TRADING
#   4. Start with MAX_LIVE_NOTIONAL_USD=10 for the first trade
#   5. Monitor the live_trader.log file closely
# ---------------------------------------------------------------------------
